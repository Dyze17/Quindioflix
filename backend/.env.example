# ============================================================
# QuindioFlix — Configuración de conexión a Oracle
# ============================================================
# Copia este archivo como ".env" en la carpeta backend/ y
# edita los valores según tu entorno local:
#
#   cp .env.example .env       (Linux / macOS)
#   copy .env.example .env     (Windows)
#
# IMPORTANTE: El archivo ".env" NO debe subirse al repositorio.
# ============================================================

# Usuario con el que se conecta la API a Oracle
# (el usuario del esquema que ejecutó los scripts 01-06)
DB_USER=DHI

# Contraseña de ese usuario Oracle
DB_PASSWORD=12345

# Cadena de conexión Oracle  →  host:puerto/nombre_del_servicio
# Ejemplos:
#   localhost:1521/XEPDB1        (Oracle XE 21c — PDB por defecto)
#   localhost:1521/ProyectoBD2   (PDB creado manualmente)
#   192.168.1.10:1521/ORCL       (servidor remoto)
DB_DSN=localhost:1521/XEPDB1